# ============================================
# 敏感文件监控规则
# ============================================

# 用户和认证文件
-w /etc/passwd -p wa -k passwd_changes
-w /etc/shadow -p rwa -k shadow_changes
-w /etc/group -p wa -k group_changes
-w /etc/gshadow -p rwa -k gshadow_changes
-w /etc/security/opasswd -p wa -k opasswd_changes

# SSH 配置和密钥
-w /etc/ssh/sshd_config -p wa -k sshd_config
-w /etc/ssh/ssh_config -p wa -k ssh_config
-w /root/.ssh/ -p wa -k root_ssh_keys

# Sudo 配置
-w /etc/sudoers -p wa -k sudoers_changes
-w /etc/sudoers.d/ -p wa -k sudoers_changes

# 系统启动和服务
-w /etc/systemd/ -p wa -k systemd_changes
-w /usr/lib/systemd/ -p wa -k systemd_changes
-w /etc/init.d/ -p wa -k init_changes
-w /etc/init/ -p wa -k init_changes

# 定时任务
-w /etc/cron.allow -p wa -k cron_changes
-w /etc/cron.deny -p wa -k cron_changes
-w /etc/cron.d/ -p wa -k cron_changes
-w /etc/cron.daily/ -p wa -k cron_changes
-w /etc/cron.hourly/ -p wa -k cron_changes
-w /etc/cron.monthly/ -p wa -k cron_changes
-w /etc/cron.weekly/ -p wa -k cron_changes
-w /etc/crontab -p wa -k cron_changes
-w /var/spool/cron/ -p wa -k cron_changes

# 内核模块
-w /sbin/insmod -p x -k module_insertion
-w /sbin/rmmod -p x -k module_removal
-w /sbin/modprobe -p x -k module_insertion
-a always,exit -F arch=b64 -S init_module -S delete_module -k kernel_modules
-a always,exit -F arch=b32 -S init_module -S delete_module -k kernel_modules

# PAM 配置
-w /etc/pam.d/ -p wa -k pam_changes
-w /etc/security/limits.conf -p wa -k security_limits

# 系统库
-w /lib -p wa -k system_lib_changes
-w /lib64 -p wa -k system_lib_changes
-w /usr/lib -p wa -k system_lib_changes
-w /usr/lib64 -p wa -k system_lib_changes

# 重要二进制文件
-w /bin -p wa -k bin_changes
-w /sbin -p wa -k sbin_changes
-w /usr/bin -p wa -k usr_bin_changes
-w /usr/sbin -p wa -k usr_sbin_changes
-w /usr/local/bin -p wa -k local_bin_changes
-w /usr/local/sbin -p wa -k local_sbin_changes

# 系统配置文件
-w /etc/profile -p wa -k profile_changes
-w /etc/bashrc -p wa -k bashrc_changes
-w /etc/bash.bashrc -p wa -k bash_bashrc_changes
-w /etc/environment -p wa -k environment_changes

# SELinux 配置
-w /etc/selinux/ -p wa -k selinux_changes

# AppArmor 配置
-w /etc/apparmor/ -p wa -k apparmor_changes
-w /etc/apparmor.d/ -p wa -k apparmor_changes
